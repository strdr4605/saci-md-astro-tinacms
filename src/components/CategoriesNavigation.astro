---
const allCategories = Object.values(
  import.meta.glob("../../content/categories/*.md", { eager: true }),
);

const allProducts = Object.values(
  import.meta.glob("../../content/products/*.md", { eager: true }),
);

// Map categories to a product for preview in the navigation
const categoriesWithPreview = allCategories
  .map((category: any) => {
    const product = allProducts.find((p: any) =>
      category.file.includes(p.frontmatter.categoryPath),
    );

    if (!product) return null;

    return {
      category,
      product,
    };
  })
  .filter(Boolean);
---

{categoriesWithPreview.length > 0 && (
  <nav id="categories-nav" class="mt-16">

    {<!-- Mobile scrollable navigation (visible on small screens) -->}
    <div class="relative overflow-x-auto pb-2 md:hidden">
      <ul class="flex gap-4 px-4 whitespace-nowrap">
        {categoriesWithPreview.map(({ category, product }: any) => (
          <li class="flex-shrink-0">
            <a href={`#${category.frontmatter.name}`}>
              <div class="flex flex-col items-center rounded-lg bg-gray-100 px-4 py-3 hover:bg-gray-200 transition">
                <img
                  src={product.frontmatter.imgSrc}
                  alt={product.frontmatter.name}
                  class="h-30 w-30 object-contain mb-2"
                />
                <span class="uppercase text-sm font-medium">
                  {category.frontmatter.name}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* Desktop grid */}
    <ul class="hidden justify-center gap-4 sm:flex">
      {categoriesWithPreview.map(({ category, product }: any) => (
        <li class="flex flex-1">
          <a class="flex flex-1" href={`#${category.frontmatter.name}`}>
            <div class="flex flex-1 flex-col items-center rounded-lg bg-gray-100 p-4 hover:bg-gray-200 transition">
              <img
                src={product.frontmatter.imgSrc}
                alt={product.frontmatter.name}
                class="h-40 w-40 object-contain mb-3"
              />
              <span class="uppercase font-medium">
                {category.frontmatter.name}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </nav>
)}
