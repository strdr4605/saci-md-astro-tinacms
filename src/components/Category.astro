---
import CategoryProduct from "./CategoryProduct.astro";

const roProducts = Object.values(
  import.meta.glob("../../content/ro/products/*.md", { eager: true }),
) as any[];
const enProducts = Object.values(
  import.meta.glob("../../content/en/products/*.md", { eager: true }),
) as any[];
const ruProducts = Object.values(
  import.meta.glob("../../content/ru/products/*.md", { eager: true }),
) as any[];

const { categoryRo, categoryEn, categoryRu, categoryKey, index } = Astro.props;

function getKey(filepath: string) {
  return (
    filepath
      .replace(/\\/g, "/")
      .split("/")
      .pop()
      ?.replace(".md", "") ?? ""
  );
}

const inCategory = (p: any) =>
  getKey(p.frontmatter.categoryPath ?? "") === categoryKey;

const allProductKeys = [
  ...new Set(
    [...roProducts, ...enProducts, ...ruProducts]
      .filter(inCategory)
      .map((p) => getKey(p.file)),
  ),
];

const products = allProductKeys.map((key) => ({
  ro: roProducts.find((p) => getKey(p.file) === key),
  en: enProducts.find((p) => getKey(p.file) === key),
  ru: ruProducts.find((p) => getKey(p.file) === key),
}));

const isAlt = index % 2 === 1;
const bandClass = isAlt ? "bg-[#F6F5F3]" : "bg-[#F0F0F0]";
---

{
  products.length > 0 && (
    <section
      id={categoryKey}
      class={`w-full ${bandClass} border-t border-neutral-200/70`}
    >
      <div class="w-full px-6 py-10 sm:px-10 lg:px-14">
        <h2 class="flex items-center gap-6 text-3xl text-neutral-700">
          <a href={`#${categoryKey}`}>
            <span class="lang-ro">{categoryRo?.frontmatter.name}</span>
            <span class="lang-en">{categoryEn?.frontmatter.name}</span>
            <span class="lang-ru">{categoryRu?.frontmatter.name}</span>
          </a>
          <div class="h-[1px] flex-1 bg-neutral-300/80" />
        </h2>

        <ul class="mt-6 flex flex-col flex-wrap items-center md:flex-row md:items-stretch">
          {products.map(({ ro, en, ru }) => (
            <li>
              <CategoryProduct productRo={ro} productEn={en} productRu={ru} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
